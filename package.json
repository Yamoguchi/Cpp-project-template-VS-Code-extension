{
  "name": "cpp-template-generator",
  "displayName": "C++ Template Generator",
  "description": "Create a CMake C++ project template with optional vcpkg support.",
  "version": "0.1.0",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yamoguchi/Cpp-project-template-VS-Code-extension.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cppTemplateGenerator.createProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cppTemplateGenerator.createProject",
        "title": "C++ Template: Create Project"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package:vsix": "vsce package --no-dependencies",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.7.2"
  }
}
